<!DOCTYPE plugin SYSTEM "plugin://META-INF/plugin.xml">
<idea-plugin>
    <id>com.astrbot.ide.buddy</id>
    <name>AstrBot Buddy</name>
    <version>1.0.0</version>
    <vendor>AstrBot Team</vendor>

    <description>
        IntelliJ Plugin for AstrBot Development.
        Features: Status Panel, Plugin Template Generator, Debug Integration.
    </description>

    <depends>com.intellij.modules.platform</depends>

    <extensions defaultExtensionNs="com.intellij">
        <toolWindow id="AstrBot Buddy"
                    secondary="false"
                    icon="/icons/astrbot.png"
                    factoryClass="com.astrbot.ide.AstrBotBuddyToolWindowFactory"/>
    </extensions>

    <actions>
        <group id="AstrBotBuddy.MainMenu" text="AstrBot Buddy" description="AstrBot Buddy Menu">
            <add-to-group group-id="MainMenu" anchor="last"/>
            <action id="AstrBotBuddy.NewPlugin"
                    class="com.astrbot.ide.actions.NewPluginAction"
                    text="New AstrBot Plugin"
                    description="Generate a new AstrBot plugin from template"/>
        </group>
        <action id="AstrBotBuddy.NewPluginFromProject"
                class="com.astrbot.ide.actions.NewPluginAction"
                text="New AstrBot Plugin">
            <add-to-group group-id="NewGroup" anchor="last"/>
        </action>
    </actions>

    <projectListeners>
        <listener class="com.astrbot.ide.AstrBotPlugin" projectOpened="projectOpened"/>
    </projectListeners>
</idea-plugin>
